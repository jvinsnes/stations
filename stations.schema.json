{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Stations",
    "type": "array",
    "items": {
        "title": "Station",
        "type": "object",
        "required": [
            "id",
            "osm_id",
            "brand",
            "location",
            "address",
            "lat",
            "lon",
            "fuel_types"
        ],
        "additionalProperties": false,
        "properties": {
            "id": {
                "type": "string",
                "format": "uuid",
                "description": "Random UUID generated by the person who added the station",
                "examples": [
                    "a3bb189e-8bf9-3888-9912-ace4e6543002"
                ]
            },
            "osm_id": {
                "type": [
                    "string",
                    "null"
                ],
                "description": "OpenStreetMap ID. Null if not on OpenStreetMap yet",
                "examples": [
                    "7633012856",
                    "null"
                ]
            },
            "brand": {
                "type": "string",
                "enum": [
                    "AUTOMAT_1",
                    "AUTON",
                    "BECK_OLJESENTER",
                    "BEST",
                    "BILXTRA",
                    "BONDETANKEN",
                    "BUNKER_OIL",
                    "BUSKERUD_OLJE",
                    "CIRCLE_K",
                    "COOP",
                    "DALHOLEN_BENSIN",
                    "DRIV",
                    "ELSTAD_OLJESENTER",
                    "ELVDALS_BENSIN",
                    "ENGENS_OLJESENTER",
                    "ESSO",
                    "FINA",
                    "FINSLAND_BENSIN",
                    "FLORO_BIL_OG_HAVNESERVICE",
                    "FUEL4U",
                    "HALSOIL",
                    "HALTBAKK_EXPRESS",
                    "HAUGALAND_OLJE",
                    "HELGELAND_OLJESERVICE",
                    "HERNES_OLJESENTER",
                    "INDEPENDENT",
                    "JOKER",
                    "KNAPPHUS",
                    "KOTSOY_NAERINGSBYGG",
                    "LESJA_INNKJOPSLAG",
                    "LONGVA_SERVICESENTER",
                    "LYSE",
                    "MATKROKEN",
                    "MAX",
                    "MESNALI_BENSIN",
                    "MINOL",
                    "MH24",
                    "MOE_MASKIN_OG_TRANSPORT",
                    "NORSK_OLJE",
                    "NAERBUTIKKEN",
                    "KNARREN",
                    "OLJELEVERANDOREN",
                    "OTHER",
                    "PREEM",
                    "STEIGEN_OLJESERVICE",
                    "ST1",
                    "SVALBARD_AUTO",
                    "TANGSTAD_TRANSPORT",
                    "TANK",
                    "TANKEN",
                    "TOFTE_TANKTRANSPORT",
                    "TRONDER_OIL",
                    "UNO_X",
                    "YX",
                    "YX_TRUCK"
                ],
                "examples": [
                    "CIRCLE_K",
                    "YX",
                    "UNO_X"
                ]
            },
            "location": {
                "type": "string",
                "description": "Name of the location where the station is. Typically what a local would call the station.",
                "examples": [
                    "Kvinesdal",
                    "Sandvika",
                    "Trondheim sentrum"
                ]
            },
            "address": {
                "type": "string",
                "description": "Full address including street name, postal code and municipality",
                "examples": [
                    "Øyesletta 60, 4484 Øyestranda",
                    "Storgata 1, 0155 Oslo"
                ]
            },
            "lat": {
                "type": "number",
                "minimum": -90,
                "maximum": 90,
                "examples": [
                    58.2800346
                ]
            },
            "lon": {
                "type": "number",
                "minimum": -180,
                "maximum": 180,
                "examples": [
                    6.8952643
                ]
            },
            "fuel_types": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": [
                        "DIESEL",
                        "GASOLINE_95",
                        "GASOLINE_98",
                        "COLORED_DIESEL",
                        "HVO100"
                    ]
                },
                "minItems": 1,
                "uniqueItems": true,
                "examples": [
                    [
                        "DIESEL",
                        "GASOLINE_95",
                        "GASOLINE_98"
                    ],
                    [
                        "DIESEL"
                    ]
                ]
            }
            "external_id": {
                "type": "object",
                "description": "Reference ID to another source than OSM",
                "required": [
                  "id",
                  "source"
                ],
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "The ID in the external system",
                    "examples": [
                      "100115738nb",
                      "best-farstad-automat-10400626"
                    ]
                  },
                  "source": {
                    "type": "string",
                    "description": "The external system this ID belongs to",
                    "enum": [
                      "circlek",
                      "esso",
                      "tronder",
                      "yx"
                    ]
                  }
                }
            }
        }
    }
}
